# PostgreSQL connection string (durable storage for links and click events)
DATABASE_URL=postgres://shortener:shortener@localhost:5432/shortener

# Redis connection string (cache for the slug -> target URL hot path)
REDIS_URL=redis://localhost:6379

# Public origin used when rendering short links in the UI
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional: PEM-encoded CA certificate used to verify the database TLS
# connection. Set this for managed Postgres whose certificate is signed by a
# private CA (the connection is then fully verified). Leave unset for the local,
# non-TLS Docker Postgres.
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
